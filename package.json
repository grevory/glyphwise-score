      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "opentype.js": "^1.3.4"
  },
  "dependencies": {
    "apca-w3": "^0.1.9"
  },
  "devDependencies": {
    "@types/opentype.js": "^1.3.8",
    "opentype.js": "^1.3.4",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
